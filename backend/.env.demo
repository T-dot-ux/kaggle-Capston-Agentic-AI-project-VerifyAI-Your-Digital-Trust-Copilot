# VerifyAI Backend Environment Variables (Demo)
# Note: Rename this file to .env and replace the placeholder values with your actual keys.

# Database (Supabase PostgreSQL URL)
# Uncomment the line below and add your actual Supabase URL to use Postgres
# DATABASE_URL=postgresql://postgres:your-password@db.your-project.supabase.co:5432/postgres
DATABASE_URL=sqlite:///./verifyai_mock.db

# Redis / Celery Config (e.g. Upstash)
CELERY_BROKER_URL=redis://default:password@your-redis-url:6379/0
CELERY_RESULT_BACKEND=redis://default:password@your-redis-url:6379/0

# External APIs
GEMINI_API_KEY=your_gemini_api_key_here
CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
